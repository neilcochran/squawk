{
  "name": "squawk-atlas",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "The official Squawk viewer - a chart-first web app for browsing aeronautical data, built on the @squawk/* packages.",
  "license": "MIT",
  "author": "Neil Cochran",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neilcochran/squawk-atlas.git"
  },
  "homepage": "https://github.com/neilcochran/squawk-atlas#readme",
  "bugs": {
    "url": "https://github.com/neilcochran/squawk-atlas/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vitest": "^4.0.0"
  }
