{
  "name": "@squawk/navaids",
  "version": "0.2.3",
  "type": "module",
  "description": "Navaid queries by identifier, frequency, type, location, or name search",
  "author": "Neil Cochran",
  "license": "MIT",
  "homepage": "https://github.com/neilcochran/squawk",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neilcochran/squawk.git",
    "directory": "packages/navaids"
  },
  "engines": {
    "node": ">=22"
  },
  "typedocMain": "src/index.ts",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test 'dist/**/*.spec.js'",
    "lint": "tsc --noEmit && eslint src",
    "lint:pack": "publint && attw --pack . --profile esm-only"
  },
  "dependencies": {
    "@squawk/geo": "*",
    "@squawk/types": "*"
  },
  "devDependencies": {
    "@squawk/navaid-data": "*",
    "@types/node": "^25.6.0"
  },
  "keywords": [
    "aviation",
    "typescript",
    "navaid",
    "vor",
    "ndb",
    "dme",
    "tacan",
    "faa",
    "nasr"
  ],
  "publishConfig": {
    "access": "public"
  }
}
