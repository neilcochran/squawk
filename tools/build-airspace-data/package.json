{
  "name": "@squawk/build-airspace-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal build script: processes FAA NASR source files into the airspace GeoJSON dataset",
  "author": "Neil Cochran",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --test 'dist/**/*.spec.js'",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-include='dist/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info 'dist/**/*.spec.js'",
    "start": "node dist/index.js",
    "validate": "node validate.mjs",
    "viewer": "npx http-server ../.. -p 8080 -o /scripts/build-airspace-data/viewer.html"
  },
  "dependencies": {
    "@squawk/build-shared": "*",
    "@squawk/types": "*",
    "adm-zip": "^0.5.17",
    "fast-xml-parser": "^5.7.2",
    "shapefile": "^0.6.6"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^25.6.0"
  }
}
