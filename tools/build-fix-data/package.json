{
  "name": "@squawk/build-fix-data",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Internal build script: processes FAA NASR fix data into the fix dataset",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "node --test 'dist/**/*.spec.js'",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-include='dist/**' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info 'dist/**/*.spec.js'",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@squawk/build-shared": "*",
    "@squawk/types": "*",
    "adm-zip": "^0.5.17"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^25.6.0"
  }
}
