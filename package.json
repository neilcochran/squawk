{
  "name": "squawk",
  "private": true,
  "type": "module",
  "description": "Modular TypeScript libraries for building aviation applications - airspace geometry, weather parsing, flight planning, and more.",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*",
    "tools/build-shared",
    "tools/build-airspace-data",
    "tools/build-icao-registry-data",
    "tools/build-airport-data",
    "tools/build-navaid-data",
    "tools/build-fix-data",
    "tools/build-airway-data",
    "tools/build-procedure-data"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "lint:pack": "turbo run lint:pack",
    "dev": "turbo run dev",
    "docs": "typedoc",
    "build:data": "node scripts/build-data.js",
    "clean": "node scripts/clean.js",
    "publish": "changeset publish",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.6.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "publint": "^0.3.18",
    "turbo": "^2.9.6",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.58.2"
  }
}
