{
  "name": "squawk",
  "private": true,
  "description": "Modular TypeScript libraries for building aviation applications - ADS-B ingestion, airspace geometry, and more.",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "packages/*",
    "scripts/build-airspace-data",
    "scripts/build-icao-registry-data",
    "scripts/build-airport-data",
    "scripts/build-navaid-data",
    "scripts/build-fix-data",
    "scripts/build-airway-data",
    "scripts/map-viewer"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "dev": "turbo run dev",
    "docs": "typedoc",
    "clean": "node scripts/clean.js",
    "publish": "changeset publish",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typedoc": "^0.28.18",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
